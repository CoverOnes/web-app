# Gateway base URL — all API calls are routed through the CoverOnes gateway.
# Auth routes: POST /v1/auth/{register,login,refresh,logout}
# Protected routes: /api/:svc/* (gateway strips /api/:svc before forwarding)
VITE_API_BASE_URL=http://localhost:8080

# ---- OAuth social login (Google OIDC + LINE v2.1) ----
# NOTE: ALL OAuth provider credentials live in the user service env (USER_OAUTH_*),
# NEVER in the web-app bundle. The SPA only navigates to the gateway-fronted start
# endpoint (VITE_API_BASE_URL + /v1/auth/oauth/:provider/start) and receives tokens
# back at /oauth/callback. No client_id / secret is ever shipped to the browser.
#
# Dev redirect URIs to register in the provider consoles (gateway-fronted):
#   http://localhost:8080/v1/auth/oauth/google/callback
#   http://localhost:8080/v1/auth/oauth/line/callback

# ---- Feature flags (optional build-time overrides) ----
# Settings (社群帳號綁定 binding surface) is enabled by default. To force it off:
# VITE_FF_AVATAR_SETTINGS=false
